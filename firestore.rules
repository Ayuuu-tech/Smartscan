rules_version = '2';

// ScanMate Firestore security rules.
// Each user can only read/write documents under their own uid.
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{userId}/documents/{docId}
    match /users/{userId}/documents/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // (Optional) the user's own top-level doc, if you add one later.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Everything else is denied by default.
  }
}
